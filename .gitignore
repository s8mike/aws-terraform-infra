cat > .gitignore << EOF
# Terraform state - never commit
*.tfstate
*.tfstate.backup
.terraform/
.terraform.lock.hcl
crash.log

#learnings
learning_points.md
Working_doc.md
stage-docs
aws-console-setup
console_setup.md
vpc-documentation
# project_Diagram
README.md
# Secrets
*.tfvars
!*.tfvars.example

# OS
.DS_Store
EOF

*.tfplan
"plan-output*.txt"

recovery-imports.sh
README-recovery.sh
AWS-Manual-Clean-up.md
apps/mecandjeo-dashboard/phase1
apps/mecandjeo-dashboard/phase2
apps/mecandjeo-dashboard/phase3
apps/mecandjeo-dashboard/phase4/generate-dockerhub-token.md
apps/mecandjeo-dashboard/phase4/phase4-task.md

apps/mecandjeo-dashboard/phase4/generate-dockerhub_token.md
**/*token*
**/*secret*
**/*credential*
